{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Humanize Docs",
  "description": "Documentation for Humanize — AI-moderated qualitative research.",
  "colors": {
    "primary": "#2C5F8A",
    "light": "#5B8AB5",
    "dark": "#234C6E"
  },
  "background": {
    "light": "#FFFEFE",
    "dark": "#1A1A18"
  },
  "fonts": {
    "family": "IBM Plex Sans"
  },
  "favicon": "/favicon.png",
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["introduction", "quickstart"]
          },
          {
            "group": "Your Study",
            "pages": [
              "study/creating-a-study",
              "study/discussion-guides",
              "study/stimulus",
              "study/screeners",
              "study/recruiting-and-sessions",
              "study/segments-and-quotas",
              "study/study-review"
            ]
          },
          {
            "group": "Your Results",
            "pages": [
              "results/what-you-get",
              "results/summary",
              "results/deep-dive",
              "results/themes",
              "results/emotion-analysis",
              "results/supercuts",
              "results/explore",
              "results/exporting"
            ]
          }
        ]
      },
      {
        "tab": "Resources",
        "groups": [
          {
            "group": "Support",
            "pages": ["resources/faq", "resources/security-and-privacy"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "App",
          "href": "https://go.humanize.app",
          "icon": "arrow-up-right-from-square"
        }
      ]
    }
  },
  "redirects": [
    {
      "source": "/results/video-clips",
      "destination": "/results/supercuts"
    }
  ],
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@humanize.app"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open App",
      "href": "https://go.humanize.app"
    }
  },
  "footer": {
    "socials": {
      "website": "https://humanize.app"
    }
  }
}
